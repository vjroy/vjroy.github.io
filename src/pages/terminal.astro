---
// Easter egg: the original terminal-style portfolio, preserved verbatim and
// kept fully self-contained (its own dark theme + script, no shared globals).
// Reached via the subtle "terminal" link in the footer.
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Veejhay Roy — terminal." />
    <meta name="robots" content="noindex" />
    <title>veejhay@portfolio:~$</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
    <style is:global>
        :root {
            --bg:     #0d1117;
            --text:   #e6edf3;
            --green:  #3fb950;
            --blue:   #58a6ff;
            --orange: #e3b341;
            --dim:    #6e7681;
            --red:    #f85149;
            --border: #21262d;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { height: 100%; background: var(--bg); }
        body {
            height: 100%;
            background: var(--bg);
            color: var(--text);
            font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', 'Courier New', monospace;
            font-size: 14px;
            line-height: 1.7;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            transition: background 0.25s ease, color 0.25s ease;
        }
        .terminal {
            display: flex;
            flex-direction: column;
            height: 100vh;
            height: 100dvh;
            max-width: 880px;
            margin: 0 auto;
            padding: 36px 44px 20px;
        }
        .output {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding-bottom: 16px;
            scrollbar-width: none;
            scroll-behavior: smooth;
        }
        .output::-webkit-scrollbar { display: none; }
        .line {
            display: block;
            white-space: pre-wrap;
            word-break: break-word;
            line-height: 1.7;
            min-height: 1em;
        }
        .mobile-cmds {
            display: none;
            gap: 6px;
            padding: 10px 0 6px;
            overflow-x: auto;
            flex-shrink: 0;
            scrollbar-width: none;
        }
        .mobile-cmds::-webkit-scrollbar { display: none; }
        .mobile-cmd {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--blue);
            font-family: inherit;
            font-size: 12px;
            padding: 4px 12px;
            border-radius: 4px;
            cursor: pointer;
            white-space: nowrap;
            flex-shrink: 0;
            transition: background 0.15s ease, border-color 0.15s ease;
        }
        .mobile-cmd:active { background: var(--border); }
        .input-row {
            display: flex;
            align-items: center;
            flex-shrink: 0;
            padding-top: 10px;
            border-top: 1px solid var(--border);
            transition: border-color 0.25s ease;
        }
        .ps1 { white-space: nowrap; user-select: none; flex-shrink: 0; margin-right: 8px; }
        .ps1-user   { color: var(--green); font-weight: 600; }
        .ps1-at     { color: var(--green); }
        .ps1-host   { color: var(--green); font-weight: 600; }
        .ps1-colon  { color: var(--dim); }
        .ps1-dir    { color: var(--blue); font-weight: 600; }
        .ps1-dollar { color: var(--dim); margin-left: 3px; }
        .input-wrap { flex: 1; display: flex; align-items: center; min-width: 0; overflow: hidden; }
        .cmd-input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: var(--text);
            font-family: inherit;
            font-size: inherit;
            line-height: inherit;
            caret-color: var(--green);
            min-width: 0;
            transition: color 0.25s ease, caret-color 0.25s ease;
        }
        .cursor {
            color: var(--green);
            animation: blink 1s step-end infinite;
            user-select: none;
            pointer-events: none;
            flex-shrink: 0;
            transition: color 0.25s ease;
        }
        .cursor.hidden { display: none; }
        @keyframes blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
        .c-green  { color: var(--green); }
        .c-blue   { color: var(--blue); }
        .c-orange { color: var(--orange); }
        .c-dim    { color: var(--dim); }
        .c-red    { color: var(--red); }
        .c-white  { color: var(--text); }
        body::after {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.025) 2px, rgba(0,0,0,0.025) 4px);
            pointer-events: none;
            z-index: 9999;
        }
        .back-link {
            position: fixed;
            top: 14px;
            right: 16px;
            z-index: 10000;
            color: var(--dim);
            font-size: 12px;
            text-decoration: none;
            border: 1px solid var(--border);
            padding: 3px 10px;
            border-radius: 4px;
            transition: color 0.2s, border-color 0.2s;
        }
        .back-link:hover { color: var(--blue); border-color: var(--blue); }
        @media (max-width: 768px) { .mobile-cmds { display: flex; } }
        @media (max-width: 640px) { .terminal { padding: 20px 20px 14px; } body { font-size: 13px; } }
        @media (max-width: 380px) { body { font-size: 12px; } }
    </style>
</head>
<body>
    <a class="back-link" href="/">← back to site</a>
    <div class="terminal" id="terminal">
        <div class="output" id="output" role="log" aria-live="polite" aria-label="Terminal output"></div>

        <div class="mobile-cmds" id="mobile-cmds" aria-label="Quick commands">
            <button class="mobile-cmd" data-cmd="about">about</button>
            <button class="mobile-cmd" data-cmd="ls">ls</button>
            <button class="mobile-cmd" data-cmd="skills">skills</button>
            <button class="mobile-cmd" data-cmd="contact">contact</button>
            <button class="mobile-cmd" data-cmd="resume">resume</button>
            <button class="mobile-cmd" data-cmd="clear">clear</button>
        </div>

        <div class="input-row" id="input-row">
            <span class="ps1" aria-hidden="true">
                <span class="ps1-user">veejhay</span><span class="ps1-at">@</span><span class="ps1-host">portfolio</span><span class="ps1-colon">:</span><span class="ps1-dir">~</span><span class="ps1-dollar">$</span>
            </span>
            <div class="input-wrap">
                <input type="text" id="cmd-input" class="cmd-input" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" aria-label="Terminal command input" />
                <span class="cursor" id="cursor" aria-hidden="true">█</span>
            </div>
        </div>
    </div>

    <script is:inline src="/terminal.js"></script>
</body>
</html>
