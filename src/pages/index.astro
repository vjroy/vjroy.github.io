---
import Base from '../layouts/Base.astro';
import Loader from '../components/Loader.astro';
import Cursor from '../components/Cursor.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import AllWork from '../components/AllWork.astro';
import Stats from '../components/Stats.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
import Atmosphere from '../components/Atmosphere.astro';
import SectionIndex from '../components/SectionIndex.astro';
---

<Base loading={true}>
  <Atmosphere />
  <Loader />
  <Cursor />
  <Nav />
  <SectionIndex />
  <main id="main">
    <Hero />
    <Marquee />
    <AllWork />
    <Stats />
    <About />
    <Footer />
  </main>

  <script>
    import '../scripts/app.ts';
  </script>
</Base>

<style is:global>
  /* Lock scroll until the loader finishes (unless reduced motion) */
  body[data-loading] {
    overflow: hidden;
    height: 100svh;
  }
</style>
