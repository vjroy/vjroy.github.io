---
// Minimal fixed top nav. Anchor links are smooth-scrolled by Lenis (see app.ts).
---
<header class="nav" data-nav>
  <div class="nav__inner wrap">
    <a class="nav__brand" href="#top" data-cursor>
      Veejhay&nbsp;Roy<span class="nav__dot">.</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    mix-blend-mode: difference;
    color: #fff; /* difference blend flips against the light bg → reads dark */
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: clamp(1rem, 0.7rem + 1vw, 1.6rem);
  }
  .nav__brand {
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: var(--step-0);
  }
  .nav__dot { color: #fff; }
  .nav__links {
    display: flex;
    gap: clamp(1.1rem, 0.5rem + 2vw, 2.4rem);
    font-size: var(--step--1);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .nav__links a {
    position: relative;
    padding-block: 2px;
  }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s var(--ease);
  }
  .nav__links a:hover::after { transform: scaleX(1); transform-origin: left; }
</style>
