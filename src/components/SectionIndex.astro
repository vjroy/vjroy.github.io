---
// Fixed bottom-left indicator: scroll-progress hairline + numbered current-section
// label (e.g. "02 — Work"). Supplementary/decorative — purely additive to nav.
const sections = [
  { id: 'top', label: 'Intro' },
  { id: 'work', label: 'Work' },
  { id: 'about', label: 'About' },
  { id: 'contact', label: 'Contact' },
];
---

<aside class="section-index" data-section-index aria-hidden="true">
  <span class="section-index__label" data-section-index-label>01 — Intro</span>
  <span class="section-index__track">
    <span class="section-index__fill" data-section-index-fill></span>
  </span>
</aside>

<script is:inline define:vars={{ sections }}>
  function initSectionIndex() {
    const root = document.querySelector('[data-section-index]');
    const labelEl = document.querySelector('[data-section-index-label]');
    const fillEl = document.querySelector('[data-section-index-fill]');
    if (!root || !labelEl || !fillEl) return;

    const pad = (n) => String(n).padStart(2, '0');
    const targets = sections
      .map((s, i) => ({ ...s, num: pad(i + 1), el: document.getElementById(s.id) }))
      .filter((s) => s.el);
    if (!targets.length) return;

    let active = targets[0];

    const setActive = (next) => {
      if (!next || next === active) return;
      active = next;
      labelEl.textContent = `${active.num} — ${active.label}`;
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          // Prefer the entry closest to the top of the viewport among those intersecting.
          const visible = entries.filter((e) => e.isIntersecting);
          if (!visible.length) return;
          visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          const match = targets.find((t) => t.el === visible[0].target);
          setActive(match);
        },
        { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
      );
      targets.forEach((t) => io.observe(t.el));
    }

    // rAF-throttled, passive scroll-progress fill.
    let ticking = false;
    const updateProgress = () => {
      ticking = false;
      const doc = document.documentElement;
      const max = doc.scrollHeight - doc.clientHeight;
      const pct = max > 0 ? Math.min(1, Math.max(0, doc.scrollTop / max)) : 0;
      fillEl.style.transform = `scaleX(${pct})`;
    };
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(updateProgress);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    updateProgress();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSectionIndex);
  } else {
    initSectionIndex();
  }
</script>

<style>
  .section-index {
    position: fixed;
    left: var(--gutter);
    bottom: clamp(1.1rem, 0.8rem + 1vw, 1.75rem);
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    pointer-events: none;
  }

  .section-index__label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .section-index__track {
    position: relative;
    display: block;
    width: clamp(48px, 6vw, 84px);
    height: 1px;
    background: var(--line);
    overflow: hidden;
  }

  .section-index__fill {
    position: absolute;
    inset: 0;
    transform-origin: left center;
    transform: scaleX(0);
    background: var(--accent);
    transition: transform 0.15s linear;
  }

  /* Keep it out of the way on small screens. */
  @media (max-width: 560px) {
    .section-index {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-index__fill {
      transition: none;
    }
  }
</style>
