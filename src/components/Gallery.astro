---
import { projects } from '../data/projects';
const total = String(projects.length).padStart(2, '0');
---

<section class="gallery" id="work" data-gallery>
  <p class="gallery__label" data-reveal>Selected work</p>

  <!-- 3D image wall -->
  <div class="gallery__stage" data-stage>
    <div class="gallery__track">
      {
        projects.map((p, i) => (
          <figure class="gslide" data-slide data-i={i} aria-hidden={i === 0 ? 'false' : 'true'}>
            <img
              src={p.image}
              alt={`${p.title} — ${p.kind}`}
              draggable="false"
              loading={i < 2 ? 'eager' : 'lazy'}
            />
          </figure>
        ))
      }
    </div>

    <button class="gallery__nav gallery__nav--prev" data-prev aria-label="Previous project">
      <span>Prev</span>
    </button>
    <button class="gallery__nav gallery__nav--next" data-next aria-label="Next project">
      <span>Next</span>
    </button>
  </div>

  <!-- Meta panels (one per project; JS toggles .is-active) -->
  <div class="gallery__meta">
    {
      projects.map((p, i) => (
        <div class={`gmeta ${i === 0 ? 'is-active' : ''}`} data-meta data-i={i}>
          <p class="gmeta__count">
            <span class="gmeta__num">{p.index}</span>
            <span class="gmeta__sep">/</span>
            <span class="gmeta__total">{total}</span>
          </p>
          <h2 class="gmeta__title">{p.title}</h2>
          <p class="gmeta__tagline">{p.tagline}</p>
          <div class="gmeta__links">
            {p.links.map((l) => (
              <a href={l.href} target="_blank" rel="noopener" data-cursor>
                {l.label}
                <span aria-hidden="true"> ↗</span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery {
    padding-block: clamp(4rem, 2rem + 7vw, 8rem);
    overflow: hidden;
  }
  .gallery__label {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--step-1);
    color: var(--ink-soft);
    margin-bottom: clamp(1.5rem, 1rem + 2vw, 2.5rem);
  }

  /* ── 3D stage ── */
  .gallery__stage {
    position: relative;
    height: clamp(300px, 46vw, 560px);
    perspective: 2200px;
    margin-inline: auto;
    touch-action: pan-y;
  }
  .gallery__track {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }
  .gslide {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(280px, 46vw, 760px);
    aspect-ratio: 1280 / 860;
    margin: 0;
    transform: translate(-50%, -50%);
    transform-origin: center center;
    transition:
      transform 0.7s var(--ease),
      opacity 0.7s var(--ease);
    will-change: transform, opacity;
    cursor: pointer;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.45);
    background: var(--bg-2);
  }
  .gslide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gslide[data-active] {
    cursor: pointer;
  }

  /* ── Side nav ── */
  .gallery__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 60;
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding: 1rem;
    transition:
      color 0.3s,
      transform 0.3s var(--ease);
  }
  .gallery__nav:hover {
    color: var(--ink);
  }
  .gallery__nav--prev {
    left: clamp(0.5rem, 2vw, 3rem);
  }
  .gallery__nav--next {
    right: clamp(0.5rem, 2vw, 3rem);
  }
  .gallery__nav--prev:hover {
    transform: translateY(-50%) translateX(-4px);
  }
  .gallery__nav--next:hover {
    transform: translateY(-50%) translateX(4px);
  }

  /* ── Meta ── */
  .gallery__meta {
    position: relative;
    text-align: center;
    margin-top: clamp(1.5rem, 1rem + 3vw, 3.5rem);
    min-height: 220px;
  }
  .gmeta {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.5s var(--ease),
      transform 0.5s var(--ease);
    pointer-events: none;
  }
  .gmeta.is-active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .gmeta__count {
    font-size: var(--step--1);
    letter-spacing: 0.2em;
    color: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .gmeta__num {
    color: var(--ink);
  }
  .gmeta__sep {
    margin-inline: 0.4em;
  }
  .gmeta__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: var(--step-3);
    letter-spacing: -0.02em;
    margin-top: 0.6rem;
  }
  .gmeta__tagline {
    color: var(--ink-soft);
    font-size: var(--step-1);
    max-width: 34ch;
    margin-top: 0.5rem;
  }
  .gmeta__links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.4rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .gmeta__links a {
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 3px;
    transition: opacity 0.3s;
  }
  .gmeta__links a:hover {
    opacity: 0.55;
  }

  @media (max-width: 600px) {
    .gallery__nav span {
      display: none;
    }
    .gallery__nav {
      padding: 1.4rem 0.6rem;
    }
    .gallery__nav--prev::after {
      content: '‹';
      font-size: 1.8rem;
    }
    .gallery__nav--next::after {
      content: '›';
      font-size: 1.8rem;
    }
  }
</style>
