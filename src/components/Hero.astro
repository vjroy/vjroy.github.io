---
// Big editorial hero. Headline split into lines for the loader reveal.
---
<section class="hero" id="top">
  <div class="wrap hero__inner">
    <p class="eyebrow hero__eyebrow" data-hero-fade>Veejhay Roy — New Jersey, US</p>

    <h1 class="hero__title">
      <span class="hero__line"><span class="hero__line-in" data-hero-line>Researcher,</span></span>
      <span class="hero__line"><span class="hero__line-in" data-hero-line>developer</span></span>
      <span class="hero__line hero__line--amp">
        <span class="hero__line-in" data-hero-line>&amp; runner.</span>
        <img class="hero__portrait" src="/pic2.jpg" alt="Veejhay Roy" data-hero-fade />
      </span>
    </h1>

    <div class="hero__foot">
      <p class="hero__lede" data-hero-fade>
        CS @ Georgia Tech ’30. I build things at the intersection of AI, mobile,
        and the outdoors — from an LLM spatial-reasoning benchmark to an iOS app
        used by 100+ athletes.
      </p>
      <a class="hero__scroll" href="#work" data-cursor data-hero-fade>
        <span>Selected work</span>
        <span class="hero__arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: clamp(2rem, 1rem + 4vw, 4rem);
  }
  .hero__inner { width: 100%; }
  .hero__eyebrow { margin-bottom: clamp(1.5rem, 1rem + 3vw, 3rem); }

  .hero__title {
    font-family: var(--font-serif);
    font-size: var(--display);
    line-height: 0.92;
    letter-spacing: -0.02em;
    font-weight: 300;
  }
  .hero__line--amp .hero__line-in { font-style: italic; }
  .hero__line { display: block; overflow: hidden; }
  .hero__line-in { display: inline-block; }

  .hero__line--amp {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 0.5rem + 3vw, 3.5rem);
    flex-wrap: wrap;
  }
  .hero__portrait {
    width: clamp(70px, 6vw + 40px, 150px);
    height: clamp(70px, 6vw + 40px, 150px);
    border-radius: 999px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero__foot {
    margin-top: clamp(2.5rem, 1.5rem + 5vw, 5rem);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .hero__lede {
    max-width: 46ch;
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  .hero__scroll {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--step--1);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }
  .hero__arrow {
    display: inline-grid;
    place-items: center;
    width: 2.2em; height: 2.2em;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: transform 0.4s var(--ease), background 0.3s, color 0.3s;
  }
  .hero__scroll:hover .hero__arrow {
    transform: translateY(3px);
    background: var(--ink);
    color: var(--bg);
  }

  /* Loader-driven reveal initial state (JS clears these) */
  :global(body[data-loading]) .hero__line-in { transform: translateY(110%); }
  :global(body[data-loading]) [data-hero-fade] { opacity: 0; }

  @media (max-width: 600px) {
    .hero__foot { flex-direction: column; align-items: flex-start; }
  }
</style>
