---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Hide global chrome (custom cursor) — used by the terminal route. */
  bare?: boolean;
  /** Start with the intro loader / scroll lock (home page only). */
  loading?: boolean;
}

const {
  title = 'Veejhay Roy — CS @ Georgia Tech',
  description = 'Veejhay Roy — CS student at Georgia Tech. LLM researcher, iOS developer, and competitive runner.',
  bare = false,
  loading = false,
} = Astro.props;

const site = 'https://vjroy.github.io';
const ogImage = `${site}/pic2.jpg`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google" content="notranslate" />

    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Social / OG -->
    <meta property="og:title" content="Veejhay Roy" />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Veejhay Roy" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- General Sans (body/UI) — closest free match to PP Neue Montreal -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap"
    />
    <!-- Fraunces (editorial serif display) — closest free match to Editorial New -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,400&display=swap"
    />
    <!-- Mono only used by the /terminal easter egg -->
    {bare && (
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&display=swap"
      />
    )}
  </head>
  <body data-bare={bare ? 'true' : undefined} data-loading={loading ? '' : undefined}>
    {loading && (
      <script is:inline>
        // If the user prefers reduced motion, skip the loader/scroll-lock before paint.
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.body.removeAttribute('data-loading');
        }
      </script>
    )}
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
